# batch learning
class Batch:
    def train_model(data):
        model = fit(data)
        return model

class Sequential: 
    def __init__(self):
        self.weight = 0.0

    def predict(self, x):
        return self.weight * x

    def update(self, x, y, lr=0.01):
        prediction = self.predict(x)
        error = y - prediction
        self.weight += lr * error * x

# forget old knowledge
def update_with_decay(model, x, y, lr=0.01, decay=0.99):
    model.weight *= decay  # forget old knowledge
    
    prediction = model.predict(x)
    error = y - prediction
    
    model.weight += lr * error * x

def update_window(x, y):
    window.append((x, y))    
    return sum(y for _, y in window) / len(window)

def live_prediction(model, x):
    prediction = model.predict(x)    
    # simulate true value
    y = 2 * x    
    model.update(x, y)    
    return prediction

def route_and_update(segment, x, y):
    model = models[segment]
    model.update(x, y)

def track_error(pred, actual):
    errors.append(abs(pred - actual))
    
    return sum(errors) / len(errors)

# full sequential learning loop
def online_learning_system(model, stream):
    for x in stream:
        pred = model.predict(x)
        
        y = 2 * x  # simulated truth
        
        model.update(x, y)
        
        error = abs(pred - y)
        
        print({
            "input": x,
            "prediction": pred,
            "error": error,
            "weight": model.weight
        })


